# === PUNKU — .gitignore (spec 06, regla de oro #1: excluir secretos desde el primer commit) ===

# Dependencias
/node_modules
/.pnp
.pnp.js

# Builds y caché de Next.js
/.next/
/out/
/build
next-env.d.ts

# Secretos / variables de entorno (NUNCA subir — solo .env.example va al repo)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# Vercel
.vercel

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Sistema operativo / editores
.DS_Store
Thumbs.db
*.pem
.idea
.vscode/*
!.vscode/extensions.json
