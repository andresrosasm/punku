# === PUNKU — variables de entorno (NOMBRES sin valores) ===
#
# Copia este archivo como .env.local y completa con TUS propias llaves:
#     cp env.example .env.local
#
# .env.local está excluido de git (ver .gitignore). Las llaves reales viven solo
# en tu máquina y en las Environment Variables de Vercel (cofre cifrado).
#
# PUNKU funciona SIN configurar nada de esto: si faltan estas variables usa datos
# ficticios en memoria y el clasificador por reglas. La demo nunca se cae (spec 03/05).

# --- Motor de IA (spec 03) — SOLO server-side, nunca en el frontend ---
# API de Claude (Haiku) para estructurar la necesidad. Si falta -> fallback a reglas.
ANTHROPIC_API_KEY=
# Modelo (opcional; por defecto claude-haiku-4-5-20251001)
ANTHROPIC_MODEL=

# --- Supabase (specs 02, 05, 06) ---
# Si faltan, PUNKU usa un almacén en memoria con datos ficticios.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role: SOLO server-side. Acceso a la tabla `contactos` (datos sensibles).
SUPABASE_SERVICE_ROLE_KEY=

# --- Acceso al panel institucional (spec 06, regla 7) — login simbólico de demo ---
PANEL_USER=coordinador
PANEL_PASS=demo2026
